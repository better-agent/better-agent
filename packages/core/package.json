{
    "name": "@better-agent/core",
    "version": "0.1.0-canary.5",
    "description": "Better Agent core TypeScript library",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/better-agent/better-agent.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/better-agent/better-agent/tree/main/packages/core",
    "bugs": {
        "url": "https://github.com/better-agent/better-agent/issues"
    },
    "engines": {
        "bun": ">=1.0.0",
        "node": ">=20"
    },
    "type": "module",
    "types": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./events": {
            "types": "./dist/events/index.d.mts",
            "import": "./dist/events/index.mjs"
        },
        "./providers": {
            "types": "./dist/providers/index.d.mts",
            "import": "./dist/providers/index.mjs"
        },
        "./mcp": {
            "types": "./dist/mcp/index.d.mts",
            "import": "./dist/mcp/index.mjs"
        }
    },
    "typesVersions": {
        "*": {
            ".": ["dist/index.d.mts"],
            "events": ["dist/events/index.d.mts"],
            "providers": ["dist/providers/index.d.mts"],
            "mcp": ["dist/mcp/index.d.mts"]
        }
    },
    "scripts": {
        "build": "bunx tsdown",
        "dev": "bunx tsdown --watch --no-clean",
        "lint:package": "bunx publint run --strict",
        "lint:types": "npm_config_cache=../../.npm-cache bunx attw --profile esm-only --pack .",
        "lint": "bunx biome check .",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "format": "bunx biome format --write .",
        "clean": "bunx rimraf dist"
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@better-agent/shared": "workspace:*",
        "ajv": "^8.17.1",
        "@standard-schema/spec": "1.1.0",
        "json-schema-to-ts": "^3.1.1"
    },
    "devDependencies": {
        "@types/bun": "^1.2.18",
        "@types/node": "^22.15.30"
    }
}
