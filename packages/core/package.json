{
    "name": "@better-agent/core",
    "version": "0.2.0-beta.1",
    "description": "Better Agent core TypeScript library",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/better-agent/better-agent.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/better-agent/better-agent/tree/main/packages/core",
    "bugs": {
        "url": "https://github.com/better-agent/better-agent/issues"
    },
    "engines": {
        "bun": ">=1.3.3",
        "node": ">=20"
    },
    "type": "module",
    "types": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./app": {
            "types": "./dist/app/index.d.mts",
            "import": "./dist/app/index.mjs"
        },
        "./agent": {
            "types": "./dist/agent/index.d.mts",
            "import": "./dist/agent/index.mjs"
        },
        "./ag-ui": {
            "types": "./dist/ag-ui/index.d.mts",
            "import": "./dist/ag-ui/index.mjs"
        },
        "./capabilities": {
            "types": "./dist/capabilities/index.d.mts",
            "import": "./dist/capabilities/index.mjs"
        },
        "./runtime": {
            "types": "./dist/runtime/index.d.mts",
            "import": "./dist/runtime/index.mjs"
        },
        "./storage": {
            "types": "./dist/storage/index.d.mts",
            "import": "./dist/storage/index.mjs"
        },
        "./models": {
            "types": "./dist/models/index.d.mts",
            "import": "./dist/models/index.mjs"
        },
        "./plugins": {
            "types": "./dist/plugins/index.d.mts",
            "import": "./dist/plugins/index.mjs"
        },
        "./mcp": {
            "types": "./dist/mcp/index.d.mts",
            "import": "./dist/mcp/index.mjs"
        },
        "./schema": {
            "types": "./dist/schema/index.d.mts",
            "import": "./dist/schema/index.mjs"
        },
        "./tools": {
            "types": "./dist/tools/index.d.mts",
            "import": "./dist/tools/index.mjs"
        }
    },
    "typesVersions": {
        "*": {
            ".": ["dist/index.d.mts"],
            "app": ["dist/app/index.d.mts"],
            "agent": ["dist/agent/index.d.mts"],
            "ag-ui": ["dist/ag-ui/index.d.mts"],
            "capabilities": ["dist/capabilities/index.d.mts"],
            "runtime": ["dist/runtime/index.d.mts"],
            "storage": ["dist/storage/index.d.mts"],
            "models": ["dist/models/index.d.mts"],
            "plugins": ["dist/plugins/index.d.mts"],
            "mcp": ["dist/mcp/index.d.mts"],
            "schema": ["dist/schema/index.d.mts"],
            "tools": ["dist/tools/index.d.mts"]
        }
    },
    "scripts": {
        "build": "bunx tsdown",
        "dev": "bunx tsdown --watch --no-clean",
        "test": "bun test",
        "lint:package": "bunx publint run --strict",
        "lint:types": "npm_config_cache=../../.npm-cache bunx attw --profile esm-only --pack .",
        "lint": "bunx biome check .",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "format": "bunx biome format --write .",
        "clean": "bunx rimraf dist"
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@ag-ui/core": "^0.0.52",
        "@better-agent/shared": "workspace:*",
        "@cfworker/json-schema": "^4.1.1",
        "@modelcontextprotocol/client": "^2.0.0-alpha.2",
        "@standard-schema/spec": "1.1.0",
        "ajv": "^8.17.1",
        "better-call": "^2.0.3",
        "fast-json-patch": "^3.1.1",
        "json-schema-to-ts": "^3.1.1"
    },
    "devDependencies": {
        "@types/bun": "^1.3.12",
        "@types/node": "^22.19.17"
    }
}
