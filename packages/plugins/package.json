{
    "name": "@better-agent/plugins",
    "version": "0.2.0-beta.3",
    "description": "Better Agent plugins TypeScript library",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/better-agent/better-agent.git",
        "directory": "packages/plugins"
    },
    "homepage": "https://github.com/better-agent/better-agent/tree/main/packages/plugins",
    "bugs": {
        "url": "https://github.com/better-agent/better-agent/issues"
    },
    "engines": {
        "bun": ">=1.3.3",
        "node": ">=20"
    },
    "type": "module",
    "types": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "scripts": {
        "build": "bunx tsdown",
        "dev": "bunx tsdown --watch --no-clean",
        "test": "bun test __tests__",
        "lint:package": "bunx publint run --strict",
        "lint:types": "npm_config_cache=../../.npm-cache bunx attw --profile esm-only --pack .",
        "lint": "bunx biome check .",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "format": "bunx biome format --write .",
        "clean": "bunx rimraf dist"
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@better-agent/shared": "workspace:*"
    },
    "devDependencies": {
        "@better-agent/core": "workspace:*",
        "@daytonaio/sdk": "^0.161.0",
        "@types/bun": "^1.3.12",
        "@types/node": "^22.19.17",
        "e2b": "^2.19.0"
    },
    "peerDependencies": {
        "@better-agent/core": "workspace:*",
        "@daytonaio/sdk": "^0.161.0",
        "e2b": "^2.19.0"
    },
    "peerDependenciesMeta": {
        "@daytonaio/sdk": {
            "optional": true
        },
        "e2b": {
            "optional": true
        }
    }
}
