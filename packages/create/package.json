{
    "name": "create-better-agent",
    "version": "0.1.0-canary.5",
    "description": "Initialize Better Agent in an existing app",
    "license": "MIT",
    "type": "module",
    "types": "./dist/index.d.mts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/better-agent/better-agent.git",
        "directory": "packages/create"
    },
    "homepage": "https://github.com/better-agent/better-agent/tree/main/packages/create",
    "bugs": {
        "url": "https://github.com/better-agent/better-agent/issues"
    },
    "keywords": ["better-agent", "create", "cli", "ai"],
    "publishConfig": {
        "access": "public",
        "executableFiles": ["./dist/index.mjs"]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        }
    },
    "bin": {
        "create-better-agent": "./dist/index.mjs"
    },
    "scripts": {
        "build": "bunx tsdown",
        "dev": "bunx tsdown --watch --no-clean",
        "test": "bun test",
        "lint:package": "bunx publint run --strict",
        "lint:types": "npm_config_cache=../../.npm-cache bunx attw --profile esm-only --pack .",
        "lint": "bunx biome check .",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "format": "bunx biome format --write .",
        "clean": "bunx rimraf dist"
    },
    "dependencies": {
        "ink": "^6.2.2",
        "react": "^19.2.0"
    },
    "devDependencies": {
        "@types/bun": "^1.2.18",
        "@types/node": "^22.15.30",
        "@types/react": "^19.2.9"
    },
    "files": ["dist", "README.md", "templates"]
}
