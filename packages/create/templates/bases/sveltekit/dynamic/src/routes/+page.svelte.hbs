<script lang="ts">
import { createAgentChat } from "@better-agent/client/svelte";
import { client } from "$lib/better-agent/client";

const chat = createAgentChat(client.agent("{{primaryAgentName}}"), {
	threadId: "main"
});

let input = $state("");
let isBusy = $derived($chat.status === "submitted" || $chat.status === "streaming");
</script>

<svelte:head>
	<title>Better Agent</title>
</svelte:head>

<main class="min-h-screen bg-zinc-950 px-4 py-6 text-zinc-100 sm:px-6 sm:py-8">
	<section class="mx-auto grid max-w-3xl gap-4">
		<header class="grid gap-3">
			<p class="m-0 font-mono text-[11px] uppercase text-zinc-500">Generated by Better Agent</p>
			<h1 class="m-0 text-3xl font-semibold text-white sm:text-4xl">{{frameworkTitle}}</h1>
			<div class="flex items-center justify-between gap-3 border border-zinc-800 bg-zinc-900 px-3 py-2 font-mono text-[11px] uppercase text-zinc-400">
				<span>&gt;_</span>
				<span class="text-zinc-200">/agents/{{primaryAgentName}}</span>
			</div>
		</header>
		<section class="grid gap-3 border border-zinc-800 bg-zinc-900 p-3 sm:p-4">
			<div class="flex items-center justify-between gap-3 font-mono text-[11px] uppercase text-zinc-400">
				<span>thread main</span>
				<span>{$chat.status}</span>
			</div>
			<section class="grid min-h-80 gap-3 border border-zinc-800 bg-zinc-950 p-3" aria-live="polite">
				{#if $chat.messages.length === 0}
					<div class="grid place-items-center border border-dashed border-zinc-800 px-4 py-12 text-center text-sm leading-6 text-zinc-500">No messages yet.</div>
				{:else}
					<div class="grid content-start gap-3 self-start">
						{#each $chat.messages as message (message.id)}
							<article class={`max-w-[88%] border px-2.5 py-2 text-sm leading-6 ${message.role === "user" ? "ml-auto border-zinc-200 bg-white text-zinc-950" : "border-zinc-800 bg-black text-zinc-100"}`}>
								<p class="m-0 font-mono text-[9px] uppercase text-zinc-500">{message.role}</p>
								<p class="m-0 mt-1.5 whitespace-pre-wrap">{message.parts.filter((part) => part.type === "text").map((part) => part.text).join("\n") || "No text content"}</p>
							</article>
						{/each}
					</div>
				{/if}
			</section>
			<form class="grid gap-3" onsubmit={async (event) => {
				event.preventDefault();
				if (isBusy) {
					chat.stop();
					return;
				}
				const value = input.trim();
				if (!value) return;
				input = "";
				await chat.sendMessage(value);
			}}>
				<textarea bind:value={input} placeholder="Ask something..." aria-label="Message" class="min-h-24 w-full resize-none border border-zinc-800 bg-black px-3 py-2.5 text-sm leading-6 text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-zinc-200"></textarea>
				<div class="flex flex-wrap items-center justify-end gap-3">
					<button type="button" onclick={() => chat.stop()} disabled={!isBusy} class="border border-zinc-800 px-3 py-2 text-sm text-zinc-100 transition hover:border-zinc-200 disabled:cursor-not-allowed disabled:opacity-40">Stop</button>
					<button type="submit" disabled={isBusy || input.trim().length === 0} class="border border-white bg-white px-3 py-2 text-sm font-medium text-black transition hover:bg-zinc-200 disabled:cursor-not-allowed disabled:opacity-40">{isBusy ? "Streaming" : "Send"}</button>
				</div>
				{#if $chat.error}
					<p class="m-0 border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm text-red-200">{$chat.error.message}</p>
				{/if}
			</form>
		</section>
	</section>
</main>
