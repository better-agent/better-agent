{
    "name": "@better-agent/redis",
    "version": "0.2.0-beta.3",
    "description": "Better Agent Redis adapter",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/better-agent/better-agent.git",
        "directory": "packages/redis"
    },
    "homepage": "https://github.com/better-agent/better-agent/tree/main/packages/redis",
    "bugs": {
        "url": "https://github.com/better-agent/better-agent/issues"
    },
    "engines": {
        "bun": ">=1.3.3",
        "node": ">=20"
    },
    "type": "module",
    "types": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        }
    },
    "scripts": {
        "build": "bunx tsdown",
        "dev": "bunx tsdown --watch --no-clean",
        "lint:package": "bunx publint run --strict",
        "lint:types": "npm_config_cache=../../.npm-cache bunx attw --profile esm-only --pack .",
        "lint": "bunx biome check .",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "format": "bunx biome format --write .",
        "clean": "bunx rimraf dist"
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@better-agent/schema": "workspace:*",
        "@farming-labs/orm": "*",
        "@farming-labs/orm-redis": "^0.0.61"
    },
    "devDependencies": {
        "@better-agent/core": "workspace:*",
        "@types/bun": "^1.3.12",
        "@types/node": "^22.19.17"
    },
    "peerDependencies": {
        "@better-agent/core": "workspace:*",
        "@upstash/redis": ">=1 <2",
        "redis": ">=4 <6"
    },
    "peerDependenciesMeta": {
        "@upstash/redis": {
            "optional": true
        },
        "redis": {
            "optional": true
        }
    }
}
